---
import { Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  {
    depth: 2,
    slug: 'education',
    text: 'Education'
  },
  {
    depth: 2,
    slug: 'experience',
    text: 'Experience'
  },
  {
    depth: 2,
    slug: 'projects',
    text: 'Projects'
  }
]
---

<PageLayout title='About' {headings}>
  <h2 id='general-talk' class='invisible m-0 h-0'>General Talk</h2>
  <p class='text-muted-foreground'>Computer Science Undergraduate</p>
  <p>Hi, I'm Ziheng Zhang, an undergraduate student majoring in Computer Science at Shandong University.</p>
  <p>
    Recipient of the National Scholarship, Second Prize in the National Mathematical Modeling Contest (CUMCM),
    and First Prize (Provincial) in the National System Capability Competition.
  </p>
  <p>Proficient in Python and C/C++ programming with a solid foundation in algorithms and data structures.</p>
  <p>Experienced in applying machine learning and optimization algorithms to solve real-world problems.</p>
  <p>Currently conducting research training in the Elite Class of the School of Computer Science.</p>
  <p>
    <a href='/profile.pdf' download class='inline-flex items-center gap-1 font-medium underline underline-offset-4'>
      Download my Resume (PDF)
    </a>
  </p>

  <h2 id='education'>Education</h2>
  <Timeline
    events={[
      {
        date: '2023-09-01',
        content: '<a href="https://www.sdu.edu.cn/" target="_blank">Shandong University — B.Eng. in Computer Science and Technology</a>'
      }
    ]}
  />

  <h2 id='experience'>Experience</h2>
  <Timeline
    events={[
      {
        date: '2024-10-01',
        content: 'National Scholarship — Ministry of Education, China'
      },
      {
        date: '2024-11-01',
        content: 'Second Prize, National Mathematical Modeling Contest (CUMCM)'
      },
      {
        date: '2025-01-01',
        content: 'First Prize (Provincial) & 10th Place (National Finals), System Capability Competition'
      }
    ]}
  />

  <h2 id='projects'>Projects</h2>
  <p>Here are some projects I have worked on.</p>

  <h3>Competition Projects</h3>
  <ProjectSection
    projects={[
      {
        name: 'ML-based Production Optimization System',
        description: 'CUMCM National Second Prize — Built a profit optimization model for multi-process production scheduling. Designed simulated annealing and ML-enhanced versions.',
        tags: ['Python', 'NumPy', 'Pandas', 'scikit-learn'],
        links: [{ type: 'github', href: 'https://github.com/MuXinCG2004' }]
      },
      {
        name: 'OceanBase Database Performance Tuning',
        description: 'System Capability Competition — 10th Place Nationally. Performance optimization of OceanBase distributed database including query analysis, monitoring, and parameter tuning.',
        tags: ['OceanBase', 'Distributed Database', 'SQL'],
        links: [{ type: 'github', href: 'https://github.com/MuXinCG2004' }]
      }
    ]}
  />

  <h3>Research Projects</h3>
  <ProjectSection
    projects={[
      {
        name: 'EvoScientist',
        description: 'An AI research framework for building self-evolving AI scientists that autonomously explore research questions. Features multi-agent collaboration, persistent memory, and MCP integration. Ranked #1 on DeepResearch Bench II.',
        tags: ['Python', 'LangChain', 'Multi-Agent', 'LLM'],
        links: [{ type: 'github', href: 'https://github.com/EvoScientist/EvoScientist' }]
      }
    ]}
  />

  <h3>Open Source</h3>
  <ProjectSection
    projects={[
      {
        name: "MuXinCG's Blog",
        description: 'Personal blog built with Astro and astro-pure theme. Features algorithm reviews, CS229 lecture notes, and more.',
        tags: ['Astro', 'TypeScript', 'UnoCSS'],
        links: [
          { type: 'github', href: 'https://github.com/MuXinCG2004/muxincg2004.github.io' },
          { type: 'site', href: 'https://muxincg2004.github.io' }
        ]
      }
    ]}
  />
</PageLayout>
