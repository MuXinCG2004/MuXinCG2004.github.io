---
import { Image } from 'astro:assets'


import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import SkillBar from '@/components/home/SkillBar.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import AchievementTimeline from '@/components/home/AchievementTimeline.astro'
import avatar from '@/assets/avatar.jpg'
import config from '@/site-config'

const tools = ['Git', 'Linux', 'Docker', 'LaTeX']
const others = ['Data Structures & Algorithms']

const achievements = [
  {
    date: '2024',
    title: 'National Scholarship',
    description: 'Top academic honor awarded by the Ministry of Education of China.',
    icon: '🏆',
    category: 'award' as const
  },
  {
    date: '2024',
    title: 'CUMCM National Second Prize',
    description: 'National Mathematical Modeling Contest — Built ML-based production optimization system.',
    icon: '🥈',
    category: 'competition' as const
  },
  {
    date: '2024',
    title: 'System Capability Competition — Provincial First Prize',
    description: 'OceanBase database performance tuning, 10th place nationally.',
    icon: '🏅',
    category: 'competition' as const
  }
]

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const githubUser = 'MuXinCG2004'
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={avatar}
        alt='profile'
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='Shandong University, China'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='GitHub' as='a' href='https://github.com/MuXinCG2004' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label title='Resume' as='a' href='/profile.pdf' download>
            <Icon name='link' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground mt-1'>Computer Science Undergraduate</p>
        <div class='flex flex-col gap-2 leading-6 text-muted-foreground'>
          <p>Hi, I'm Ziheng Zhang, an undergraduate student majoring in Computer Science at Shandong University.</p>
          <p>
            Recipient of the National Scholarship, Second Prize in the National Mathematical Modeling Contest (CUMCM),
            and First Prize (Provincial) in the National System Capability Competition.
          </p>
          <p>Proficient in Python and C/C++ programming with a solid foundation in algorithms and data structures.</p>
          <p>Currently conducting research training in the Elite Class of the School of Computer Science.</p>
        </div>
        <Button title='More about me' class='w-fit self-end' href='/about' style='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title='Posts'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='More posts' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='Education'>
        <Card
          as='a'
          heading='Shandong University'
          subheading='B.Eng. in Computer Science and Technology'
          date='Sep 2023 - Jun 2027'
          href='https://www.sdu.edu.cn/'
        />
      </Section>

      <Section title='Achievements'>
        <AchievementTimeline events={achievements} />
      </Section>

      <Section title='Skills'>
        <div class='flex flex-col gap-y-2 md:flex-row md:gap-x-5 md:gap-y-0'>
          <h3 class='w-1/5 font-medium'>Languages</h3>
          <div class='flex flex-col gap-y-3 md:w-4/5'>
            <SkillBar name='Python' level={90} />
            <SkillBar name='C/C++' level={85} />
            <SkillBar name='Golang' level={60} />
          </div>
        </div>
        <SkillLayout title='Tools' skills={tools} />
        <SkillLayout title='Other' skills={others} />
      </Section>

      <Section title='GitHub'>
        <div class='flex flex-col items-center gap-4 sm:flex-row sm:justify-center'>
          <picture>
            <source
              srcset={`https://github-readme-stats.vercel.app/api?username=${githubUser}&show_icons=true&theme=dark&hide_border=true&bg_color=00000000`}
              media='(prefers-color-scheme: dark)'
            />
            <img
              src={`https://github-readme-stats.vercel.app/api?username=${githubUser}&show_icons=true&theme=default&hide_border=true&bg_color=00000000`}
              alt='GitHub Stats'
              loading='lazy'
              class='max-w-full'
            />
          </picture>
          <picture>
            <source
              srcset={`https://github-readme-stats.vercel.app/api/top-langs/?username=${githubUser}&layout=compact&theme=dark&hide_border=true&bg_color=00000000`}
              media='(prefers-color-scheme: dark)'
            />
            <img
              src={`https://github-readme-stats.vercel.app/api/top-langs/?username=${githubUser}&layout=compact&theme=default&hide_border=true&bg_color=00000000`}
              alt='Top Languages'
              loading='lazy'
              class='max-w-full'
            />
          </picture>
        </div>
      </Section>
    </div>
  </main>
</PageLayout>
