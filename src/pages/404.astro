---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: 'Not found',
  title: '404'
}
---

<PageLayout {meta}>
  <script is:inline>
    const url = new URL(window.location.href)
    const path = url.pathname.split('/')
    if (path.includes('posts')) {
      const newUrl = `/blog/${path.pop()}`
      window.location.href = newUrl
    }
  </script>
  <noscript>
    <div class='px-4 py-10 text-center sm:px-6 lg:px-8'>
      <p class='mt-3 text-muted-foreground'>
        If you came from an old link, please try using search to find the relevant post.
      </p>
      <p>
        <a href='/'>Back to Home</a> |
        <a href='/search'>Search</a>
      </p>
    </div>
  </noscript>
  <div class='px-4 py-10 text-center sm:px-6 lg:px-8'>
    <h1 class='block text-7xl font-bold sm:text-9xl'>404</h1>
    <p class='mt-3 text-muted-foreground'>Oops, something went wrong.</p>
    <p class='text-lg'>Sorry, we couldn't find the page you requested.</p>
    <Button title='Back to home' href='/' variant='ahead' class='mt-5' />
  </div>
</PageLayout>
