---
import { cn } from 'astro-pure/utils'

interface TimelineEvent {
  date: string
  title: string
  description?: string
  icon?: string
  category: 'award' | 'competition' | 'project' | 'education'
}

interface Props {
  events: TimelineEvent[]
  class?: string
}

const { events, class: className } = Astro.props

const categoryColors: Record<string, { bg: string; border: string; text: string }> = {
  award: { bg: 'bg-amber-100 dark:bg-amber-900/30', border: 'border-amber-400', text: 'text-amber-700 dark:text-amber-300' },
  competition: { bg: 'bg-blue-100 dark:bg-blue-900/30', border: 'border-blue-400', text: 'text-blue-700 dark:text-blue-300' },
  project: { bg: 'bg-green-100 dark:bg-green-900/30', border: 'border-green-400', text: 'text-green-700 dark:text-green-300' },
  education: { bg: 'bg-purple-100 dark:bg-purple-900/30', border: 'border-purple-400', text: 'text-purple-700 dark:text-purple-300' }
}

const categoryLabels: Record<string, string> = {
  award: 'Award',
  competition: 'Competition',
  project: 'Project',
  education: 'Education'
}
---

<div class={cn('relative', className)}>
  {events.map((event, index) => {
    const colors = categoryColors[event.category] || categoryColors.project
    return (
      <div class="relative flex gap-x-4 pb-8 last:pb-0">
        {/* Vertical line */}
        {index < events.length - 1 && (
          <div class="absolute left-[11px] top-8 h-[calc(100%-2rem)] w-px bg-border" />
        )}

        {/* Dot */}
        <div class={cn('relative z-10 mt-1.5 h-6 w-6 flex-shrink-0 rounded-full border-2 flex items-center justify-center text-xs', colors.border, colors.bg)}>
          {event.icon || ''}
        </div>

        {/* Content */}
        <div class="flex flex-1 flex-col gap-y-1">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <h4 class="font-medium text-foreground">{event.title}</h4>
            <span class={cn('inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium', colors.bg, colors.text)}>
              {categoryLabels[event.category]}
            </span>
          </div>
          <time class="text-xs text-muted-foreground">{event.date}</time>
          {event.description && (
            <p class="text-sm leading-relaxed text-muted-foreground">{event.description}</p>
          )}
        </div>
      </div>
    )
  })}
</div>
