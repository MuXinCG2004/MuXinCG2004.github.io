---
import type { CollectionEntry } from 'astro:content'
import { getFormattedDate } from 'astro-pure/utils'

interface Props {
  currentPost: CollectionEntry<'blog'>
  posts: CollectionEntry<'blog'>[]
}

const { currentPost, posts } = Astro.props
const currentTags = currentPost.data.tags ?? []

if (currentTags.length === 0) return

const MAX_RELATED = 3

const scored = posts
  .filter((p) => p.id !== currentPost.id)
  .map((p) => {
    const postTags = p.data.tags ?? []
    const commonTags = currentTags.filter((t: string) => postTags.includes(t))
    return { post: p, score: commonTags.length, commonTags }
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score
    return b.post.data.publishDate.getTime() - a.post.data.publishDate.getTime()
  })
  .slice(0, MAX_RELATED)

if (scored.length === 0) return
---

<div class="mt-3 sm:mt-6">
  <h2 class="mb-3 text-sm font-semibold text-muted-foreground uppercase tracking-wide">
    相关文章
  </h2>
  <ul class="flex flex-col gap-2">
    {scored.map(({ post, commonTags }) => (
      <li>
        <a
          href={`/blog/${post.id}`}
          class="group flex flex-col gap-1 rounded-xl border bg-muted/30 px-4 py-3 transition-colors duration-300 hover:bg-muted/50"
        >
          <span class="text-sm font-medium text-foreground transition-colors group-hover:text-primary">
            {post.data.title}
          </span>
          <span class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
            <time datetime={post.data.publishDate.toISOString()}>
              {getFormattedDate(post.data.publishDate)}
            </time>
            <span class="flex flex-wrap gap-1">
              {commonTags.map((tag: string) => (
                <span class="rounded-md bg-primary/10 px-1.5 py-0.5 text-primary">{tag}</span>
              ))}
            </span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
